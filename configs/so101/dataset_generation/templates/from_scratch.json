{
  "schema_version": 2,
  "name": "replace_me_from_scratch_v1",
  "version": "v1",
  "description": "Template for a new simulator-generated SO101 teacher dataset.",
  "source": {"mode": "from_scratch"},
  "exporter_revision": "replace-with-git-revision",
  "exporter": "scripts/export_so101_teacher_rollouts_lerobot.py",
  "merge_script": "scripts/merge_so101_lerobot_shards.py",
  "sidecar_script": "scripts/build_so101_camera_grid_bins.py",
  "closed_loop_script": "scripts/build_so101_closed_loop_start_report.py",
  "audit_script": "scripts/audit_so101_dataset_splits.py",
  "lookup_cache": "_workspace/cache/replace_me_from_scratch_v1.json",
  "common": {
    "fps": 12,
    "width": 256,
    "height": 256,
    "teacher_style": "staged",
    "approach_steps": 34,
    "settle_steps": 10,
    "close_steps": 42,
    "lift_steps": 70,
    "lift_target_height": 0.065,
    "lift_controller_z_error": 0.015,
    "trajectory_variant": "standard",
    "start_mode": "home",
    "grip_the_cube_start_profile": "home",
    "move_target_z_offset": 0.075,
    "skill_mode": "grip_the_cube_v1",
    "terminal_hold_steps": 12,
    "edge_contact_xy_success_threshold": 0.012,
    "inspection_gates": [
      {
        "kind": "geometry_contact_alignment",
        "contract": "jaw_line_vs_contact_face_normal_through_cube_center",
        "max_pre_close_error_deg": 3.0
      },
      {
        "kind": "camera2_visual_alignment",
        "camera_key": "observation.images.camera2",
        "edge_mode": "top_contact",
        "strategy": "constructive_refine_then_probe",
        "mode": "preclose_and_early_trace",
        "pre_close_max_deg": 8.0,
        "close_25_max_deg": 8.0,
        "close_50_max_deg": 8.0
      }
    ],
    "max_attempt_multiplier": 30,
    "grid_balance_size": 4,
    "grid_balance_spawn_lookup": true,
    "grid_lookup_preserve_order": true,
    "grid_lookup_x_min": -0.1,
    "grid_lookup_x_max": 0.55,
    "grid_lookup_y_min": -0.45,
    "grid_lookup_y_max": 0.45,
    "grid_lookup_resolution": 161,
    "deterministic_camera_bin_lookup": true,
    "target_object_color": "green"
  },
  "sidecar": {
    "camera_key": "observation.images.camera1",
    "grid_size": 4,
    "frame_index": 0,
    "min_area": 20
  },
  "splits": {
    "train": {
      "output_root": "_workspace/so101_lerobot/replace_me_from_scratch_v1",
      "repo_id": "physical-ai-agent/replace-me-from-scratch-v1",
      "bins": [
        {"id": 5, "episodes": 1, "seed": 100000000, "lookup_start_index": 0}
      ]
    },
    "validation": {
      "output_root": "_workspace/so101_lerobot/replace_me_from_scratch_v1_validation",
      "repo_id": "physical-ai-agent/replace-me-from-scratch-v1-validation",
      "bins": [
        {"id": 5, "episodes": 1, "seed": 110000000, "lookup_start_index": 64}
      ],
      "closed_loop": {
        "episodes": 1,
        "bins": [5],
        "output": "meta/closed_loop/replace_me_from_scratch_v1_validation_start1.json",
        "success_metric": "env_success",
        "lift_success_height": 0.05
      }
    }
  },
  "audit": {
    "expected_prompt": "grip the green cube and lift",
    "expected_resolution": [256, 256],
    "expected_min_lift_height": 0.06,
    "expected_min_lift_steps": 20,
    "terminal_hold_action_tolerance": 0.00001
  }
}
