{
  "name": "pick_from_top_cube_photoreal",
  "description": "SO101 pick-from-top primitive with training, supervised validation, and closed-loop start datasets stored as photoreal LeRobot parquet roots. Camera/state/action rows stay aligned with the source pick_from_top_cube datasets.",
  "task": "pick_from_top_cube",
  "prompt": "From above the visible cube, grasp it and lift it up.",
  "source_config": "configs/so101/training_datasets/pick_from_top_cube.json",
  "train_dataset": {
    "repo_id": "physical-ai-agent/so101-pick-from-top-cube-photoreal-train100-ego-wrist-256",
    "root": "_workspace/so101_photoreal_lerobot/pick_from_top_cube_train100_ego_wrist_256_seed112000_samples256_nodenoise",
    "source_repo_id": "physical-ai-agent/so101-pick-from-top-cube-train100-ego-wrist-256",
    "source_root": "_workspace/so101_lerobot/pick_from_top_cube_train100_ego_wrist_256_seed112000",
    "render_root": "_workspace/so101_photoreal_renders/pick_from_top_cube_train100_ego_wrist_256_seed112000_samples256_nodenoise",
    "split": "train",
    "expected_episodes": 100,
    "expected_frames": 7179,
    "dataset_format": "so101_photoreal_lerobot_v1"
  },
  "validation_dataset": {
    "repo_id": "physical-ai-agent/so101-pick-from-top-cube-photoreal-valid25-ego-wrist-256",
    "root": "_workspace/so101_photoreal_lerobot/pick_from_top_cube_valid25_ego_wrist_256_seed113000_samples256_nodenoise",
    "source_repo_id": "physical-ai-agent/so101-pick-from-top-cube-valid25-ego-wrist-256",
    "source_root": "_workspace/so101_lerobot/pick_from_top_cube_valid25_ego_wrist_256_seed113000",
    "render_root": "_workspace/so101_photoreal_renders/pick_from_top_cube_valid25_ego_wrist_256_seed113000_samples256_nodenoise",
    "split": "validation",
    "expected_episodes": 25,
    "expected_frames": 1793,
    "dataset_format": "so101_photoreal_lerobot_v1"
  },
  "loop_validation_dataset": {
    "repo_id": "physical-ai-agent/so101-pick-from-top-cube-photoreal-loop-validation10-ego-wrist-256",
    "root": "_workspace/so101_photoreal_lerobot/pick_from_top_cube_loop_validation10_ego_wrist_256_seed113500_samples256_nodenoise",
    "source_repo_id": "physical-ai-agent/so101-pick-from-top-cube-loop-validation10-ego-wrist-256",
    "source_root": "_workspace/so101_lerobot/pick_from_top_cube_loop_validation10_ego_wrist_256_seed113500",
    "render_root": "_workspace/so101_photoreal_renders/pick_from_top_cube_loop_validation10_ego_wrist_256_seed113500_samples256_nodenoise",
    "split": "loop_validation",
    "expected_episodes": 10,
    "expected_frames": 718,
    "dataset_format": "so101_photoreal_lerobot_v1"
  },
  "photoreal_render": {
    "renderer": "blender_cycles_metal",
    "env_source": "high_contrast_picklift",
    "width": 256,
    "height": 256,
    "samples": 256,
    "denoise": false,
    "robot_material": "matte_pla",
    "camera_lens": 35,
    "asset_root": "_workspace/photoreal_assets",
    "camera_pose_source": "source MuJoCo camera metadata and physical_ai_agent.sim.so101_camera_input.EGOCENTRIC_CAMERA1_POSE"
  },
  "camera_contract": {
    "observation.images.camera1": "egocentric_cam",
    "observation.images.camera2": "wrist_cam",
    "observation.images.camera3": "wrist_cam duplicate"
  },
  "training": {
    "batch_size": 32,
    "num_workers": 4,
    "steps_per_epoch": 225,
    "validation_max_batches": 16
  },
  "predecoded_image_cache": {
    "root_env": "SO101_PREDECODED_CACHE_ROOT",
    "default_root": "_workspace/so101_image_cache",
    "train": "pick_from_top_cube_train100_ego_wrist_256_seed112000_samples256_nodenoise",
    "validation": "pick_from_top_cube_valid25_ego_wrist_256_seed113000_samples256_nodenoise"
  },
  "tensorboard": {
    "log_input_images_every_n_steps": 50,
    "log_input_metadata_every_n_steps": 50
  },
  "augmentation": {
    "state_jitter_std": 0.003,
    "state_jitter_arm_only": true,
    "state_dropout_prob": 0.02,
    "state_dropout_keep_gripper": true,
    "image_camera_dropout_prob": 0.0,
    "image_patch_dropout_prob": 0.0,
    "image_patch_mask_ratio": 0.15,
    "image_color_jitter": true,
    "image_sharpness_jitter": true,
    "image_affine_degrees": 5.0,
    "image_affine_translate": 0.05,
    "gpu_image_augmentation": true
  },
  "closed_loop": {
    "eval_skill_mode": "pick_from_top_cube",
    "success_metric": "final_is_grasped > 0.5 and final_lift_height >= 0.05",
    "record_rollout_gif": true,
    "test_cases": [
      {
        "id": "pick_from_top_cube_photoreal",
        "description": "Starts from the first frame of the pick_from_top_cube photoreal loop_validation split and runs the pick_from_top_cube primitive.",
        "episodes": 10,
        "steps": 120,
        "seed": 98400,
        "start_contract": "pick_from_top_cube",
        "task_prompt": "From above the visible green cube, grasp it and lift it up.",
        "qwen_object": "green cube",
        "env_object_color": "green",
        "start_dataset": {
          "name": "pick_from_top_cube_photoreal_loop_validation",
          "repo_id": "physical-ai-agent/so101-pick-from-top-cube-photoreal-loop-validation10-ego-wrist-256",
          "root": "_workspace/so101_photoreal_lerobot/pick_from_top_cube_loop_validation10_ego_wrist_256_seed113500_samples256_nodenoise",
          "source_root": "_workspace/so101_lerobot/pick_from_top_cube_loop_validation10_ego_wrist_256_seed113500",
          "expected_episodes": 10,
          "expected_frames": 718
        }
      }
    ]
  }
}
