  "camera_contract": {
    "observation.images.camera1": "egocentric_cam",
    "observation.images.camera2": "wrist_cam",
    "observation.images.camera3": "wrist_cam duplicate"
  },
  "training": {
    "batch_size": 32,
    "num_workers": 4,
    "policy_repo_id": "mhlee1215/so101-smolvla-qwen-edge-primitives",
    "policy_push_to_hub": false,
    "steps_per_epoch": 224,
    "validation_max_batches": 32
  },
  "predecoded_image_cache": {
    "root_env": "SO101_PREDECODED_CACHE_ROOT",
    "default_root": "_workspace/so101_image_cache",
    "train": "qwen_edge_primitives_train300_ego_wrist_256",
    "validation": "qwen_edge_primitives_valid75_ego_wrist_256"
  },
  "tensorboard": {
    "log_input_images_every_n_steps": 50,
    "log_input_metadata_every_n_steps": 50
  },
  "augmentation": {
    "state_jitter_std": 0.003,
    "state_jitter_arm_only": true,
    "state_dropout_prob": 0.02,
    "state_dropout_keep_gripper": true,
    "image_camera_dropout_prob": 0.0,
    "image_patch_dropout_prob": 0.0,
    "image_patch_mask_ratio": 0.15,
    "gpu_image_augmentation": true
  },
  "closed_loop": {
    "scenario": "pick_up_cube",
    "execution_policy": "qwen_edge_chain",
    "task_prompt": "pick and lift the green cube",
    "success_metric": "qwen_edge_chain final success/grasp/lift metrics"
  }
