  },
  "validation_dataset": {
    "repo_id": "physical-ai-agent/so101-qwen-edge-primitives-valid75-ego-wrist-256",
    "root": "_workspace/so101_lerobot_merged/qwen_edge_primitives_valid75_ego_wrist_256",
