{
  "name": "pick_from_top_cube",
  "description": "SO101 pick-from-top primitive. Uses camera1=egocentric_cam and camera2=wrist_cam. Start state is at least 5 cm above the visible cube with a fully closed gripper.",
  "task": "pick_from_top_cube",
  "prompt": "From above the visible cube, grasp it and lift it up.",
  "train_dataset": {
    "repo_id": "physical-ai-agent/so101-pick-from-top-cube-train100-ego-wrist-256",
    "root": "_workspace/so101_lerobot/pick_from_top_cube_train100_ego_wrist_256_seed112000",
    "hf_repo_id": "mhlee1215/so101-nexus-sim-dataset",
    "hf_repo_type": "dataset",
    "hf_path_in_repo": "datasets/pick_from_top_cube/train",
    "split": "train",
    "expected_episodes": 100,
    "expected_frames": 7180
  },
  "validation_dataset": {
    "repo_id": "physical-ai-agent/so101-pick-from-top-cube-valid25-ego-wrist-256",
    "root": "_workspace/so101_lerobot/pick_from_top_cube_valid25_ego_wrist_256_seed113000",
    "hf_repo_id": "mhlee1215/so101-nexus-sim-dataset",
    "hf_repo_type": "dataset",
    "hf_path_in_repo": "datasets/pick_from_top_cube/validation",
    "split": "validation",
    "expected_episodes": 25,
    "expected_frames": 1792
  },
  "camera_contract": {
    "observation.images.camera1": "egocentric_cam",
    "observation.images.camera2": "wrist_cam",
    "observation.images.camera3": "wrist_cam duplicate"
  },
  "training": {
    "batch_size": 32,
    "num_workers": 4,
    "steps_per_epoch": 225,
    "validation_max_batches": 16
  },
  "predecoded_image_cache": {
    "root_env": "SO101_PREDECODED_CACHE_ROOT",
    "default_root": "_workspace/so101_image_cache",
    "train": "pick_from_top_cube_train100_ego_wrist_256_seed112000",
    "validation": "pick_from_top_cube_valid25_ego_wrist_256_seed113000"
  },
  "tensorboard": {
    "log_input_images_every_n_steps": 50,
    "log_input_metadata_every_n_steps": 50
  },
  "augmentation": {
    "state_jitter_std": 0.003,
    "state_jitter_arm_only": true,
    "state_dropout_prob": 0.02,
    "state_dropout_keep_gripper": true,
    "image_camera_dropout_prob": 0.0,
    "image_patch_dropout_prob": 0.0,
    "image_patch_mask_ratio": 0.15,
    "gpu_image_augmentation": true
  },
  "closed_loop": {
    "eval_skill_mode": "pick_from_top_cube",
    "success_metric": "final_is_grasped > 0.5 and final_lift_height >= 0.05",
    "record_rollout_gif": true
  }
}
