{
  "name": "pick",
  "description": "SO101 pick/lift dataset with camera1=top_down and camera2=wrist_cam.",
  "task": "pick",
  "train_dataset": {
    "repo_id": "physical-ai-agent/so101-pick-train50-top-wrist-256",
    "root": "_workspace/so101_lerobot/pick_train50_top_wrist_256_seed98200",
    "split": "train"
  },
  "validation_dataset": {
    "repo_id": "physical-ai-agent/so101-pick-val24-top-wrist-256",
    "root": "_workspace/so101_lerobot/pick_val24_top_wrist_256_seed98100",
    "split": "validation"
  },
  "camera_contract": {
    "observation.images.camera1": "top_down",
    "observation.images.camera2": "wrist_cam",
    "observation.images.camera3": "wrist_cam duplicate"
  },
  "tensorboard": {
    "log_input_images_every_n_steps": 10,
    "log_input_metadata_every_n_steps": 10
  },
  "augmentation": {
    "state_jitter_std": 0.003,
    "state_jitter_arm_only": true,
    "state_dropout_prob": 0.02,
    "state_dropout_keep_gripper": true,
    "image_camera_dropout_prob": 0.0,
    "image_patch_dropout_prob": 0.0,
    "image_patch_mask_ratio": 0.15,
    "gpu_image_augmentation": true
  }
}
