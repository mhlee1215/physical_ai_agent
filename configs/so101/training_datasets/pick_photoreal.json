{
  "name": "pick_photoreal",
  "description": "SO101 pick/lift dataset with training and supervised validation images stored as photoreal LeRobot parquet roots. Prompts are rewritten per episode from the target object color, for example red cube, green cube, or blue cube.",
  "task": "pick",
  "source_config": "configs/so101/training_datasets/pick.json",
  "train_dataset": {
    "repo_id": "physical-ai-agent/so101-pick-cube-photoreal-train50-ego-wrist-256",
    "root": "_workspace/so101_photoreal_lerobot/pick_cube_train50_ego_wrist_256_seed98200_samples256_nodenoise",
    "source_repo_id": "physical-ai-agent/so101-pick-cube-train50-ego-wrist-256",
    "source_root": "_workspace/so101_lerobot/pick_cube_train50_ego_wrist_256_seed98200",
    "render_root": "_workspace/so101_photoreal_renders/pick_cube_train50_ego_wrist_256_seed98200_samples256_nodenoise",
    "split": "train",
    "expected_episodes": 50,
    "expected_frames": 4598,
    "dataset_format": "so101_photoreal_lerobot_v1",
    "task_prompt_source": "episode_seed_target_object_color"
  },
  "validation_dataset": {
    "repo_id": "physical-ai-agent/so101-pick-cube-photoreal-valid24-ego-wrist-256",
    "root": "_workspace/so101_photoreal_lerobot/pick_cube_valid24_ego_wrist_256_seed98100_samples256_nodenoise",
    "source_repo_id": "physical-ai-agent/so101-pick-cube-valid24-ego-wrist-256",
    "source_root": "_workspace/so101_lerobot/pick_cube_valid24_ego_wrist_256_seed98100",
    "render_root": "_workspace/so101_photoreal_renders/pick_cube_valid24_ego_wrist_256_seed98100_samples256_nodenoise",
    "split": "validation",
    "expected_episodes": 24,
    "expected_frames": 2210,
    "dataset_format": "so101_photoreal_lerobot_v1",
    "task_prompt_source": "episode_seed_target_object_color"
  },
  "photoreal_render": {
    "renderer": "blender_cycles_metal",
    "env_source": "high_contrast_picklift",
    "width": 256,
    "height": 256,
    "samples": 256,
    "denoise": false,
    "robot_material": "matte_pla",
    "camera_lens": 35,
    "asset_root": "_workspace/photoreal_assets",
    "camera_pose_source": "source MuJoCo camera metadata and physical_ai_agent.sim.so101_camera_input.EGOCENTRIC_CAMERA1_POSE"
  },
  "camera_contract": {
    "observation.images.camera1": "egocentric_cam",
    "observation.images.camera2": "wrist_cam",
    "observation.images.camera3": "wrist_cam duplicate"
  },
  "tensorboard": {
    "log_input_images_every_n_steps": 10,
    "log_input_metadata_every_n_steps": 10
  },
  "augmentation": {
    "state_jitter_std": 0.003,
    "state_jitter_arm_only": true,
    "state_dropout_prob": 0.02,
    "state_dropout_keep_gripper": true,
    "image_camera_dropout_prob": 0.0,
    "image_patch_dropout_prob": 0.0,
    "image_patch_mask_ratio": 0.15,
    "image_color_jitter": true,
    "image_sharpness_jitter": true,
    "image_affine_degrees": 5.0,
    "image_affine_translate": 0.05,
    "gpu_image_augmentation": true
  }
}
