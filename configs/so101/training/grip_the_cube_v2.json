{
  "name": "grip_the_cube_v2",
  "description": "Canonical SO101 cube grip/lift teacher dataset v2 with unique trajectories, strict pre-close geometry alignment, terminal hold, and balanced camera1 object bins.",
  "default_config": "configs/so101/training_defaults/grip_the_cube_v2_default.json",
  "scenario": "grip_the_cube",
  "execution_policy": "single_smolvla_teacher",
  "task": "grip_the_cube_v2",
  "action_mode": "absolute_qpos",
  "dataset": {
    "train_dataset": {
      "name": "grip_the_cube_v2",
      "repo_id": "physical-ai-agent/so101-grip-the-cube-v2",
      "root": "_workspace/so101_lerobot/grip_the_cube_v2",
      "grid_bin_sidecar": "_workspace/so101_lerobot/grip_the_cube_v2/meta/camera_grid_bins/observation_images_camera1_4x4_frame0.parquet",
      "expected_episodes": 300,
      "expected_frames": 41369,
      "quality_note": "All 300 teacher trajectories pass grasp/lift and <=3 degree pre-close face-normal alignment; seeds and action/state trajectory hashes are unique.",
      "grid_balance": {
        "camera_key": "observation.images.camera1",
        "grid_size": 4,
        "frame_index": 0,
        "min_area": 20,
        "bins": [5, 6, 9, 10],
        "visible_episodes": 300,
        "bin_counts": {
          "5": 75,
          "6": 75,
          "9": 75,
          "10": 75
        }
      }
    },
    "validation_dataset": {
      "name": "grip_the_cube_v2_validation",
      "repo_id": "physical-ai-agent/so101-grip-the-cube-v2-validation",
      "root": "_workspace/so101_lerobot/grip_the_cube_v2_validation",
      "grid_bin_sidecar": "_workspace/so101_lerobot/grip_the_cube_v2_validation/meta/camera_grid_bins/observation_images_camera1_4x4_frame0.parquet",
      "expected_episodes": 50,
      "expected_frames": 6888,
      "quality_note": "Spawn-disjoint validation set generated after the train lookup ranges; bins 5/6/9/10 contain 13/13/12/12 successful trajectories."
    },
    "camera_contract": {
      "observation.images.camera1": "egocentric_cam",
      "observation.images.camera2": "wrist_cam",
      "observation.images.camera3": "wrist_cam duplicate"
    },
    "prompt_contract": {
      "task": "grip the {color} {shape} and lift",
      "generated_task": "grip the green cube and lift",
      "applies_to": ["grip_the_cube_v2", "grip_the_cube_v2_validation"]
    },
    "generation": {
      "source_dataset": "generated_from_so101_teacher_rollout_seeds",
      "skill_mode": "grip_the_cube_v1",
      "target_object_color": "green",
      "target_object_shape": "cube",
      "phases": [
        "move_to_cube",
        "roll_align_with_cube_edge",
        "gripper_descend",
        "settle_aligned",
        "close",
        "lift",
        "terminal_hold"
      ],
      "alignment_contract": {
        "authoritative_geometry": "jaw_line_parallel_to_contact_face_normal_through_cube_center",
        "authoritative_geometry_metric": "cube_face_normal_parallel_error_deg",
        "maximum_error_deg": 3.0,
        "roll_alignment_phase": "roll_align_with_cube_edge",
        "roll_alignment_meaning": "adjust wrist_roll above the cube so the gripper jaw axis aligns with the selected contact face normal before descending",
        "descend_phase": "gripper_descend",
        "pre_close_required": true,
        "pre_close_edge_parallel_threshold_deg": 3.0,
        "pre_close_static_finger_xy_threshold": 0.012,
        "diagonal_edge_candidates_allowed": false,
        "teacher_time_wrist_roll_refinement": true,
        "close_phase_contact_edge_gate": true
      },
      "dataset_generation_augmentation": {
        "kind": "teacher_trajectory_generation",
        "terminal_hold_included": true,
        "balanced_camera1_bins": [5, 6, 9, 10]
      }
    }
  },
  "training_config": {
    "data_loading": {
      "predecoded_image_cache": {
        "root_env": "SO101_PREDECODED_CACHE_ROOT",
        "default_root": "_workspace/so101_image_cache",
        "train": "grip_the_cube_v2",
        "validation": "grip_the_cube_v2_validation"
      }
    },
    "closed_loop": {
      "test_cases": [
        {
          "id": "grip_the_cube_v2",
          "episodes": 10,
          "steps": 120,
          "seed": 98100,
          "start_contract": "dataset_episode_start",
          "task_prompt": "grip the green cube and lift",
          "env_object_color": "green",
          "success_metric": "env_success",
          "start_report_path": "_workspace/so101_lerobot/grip_the_cube_v2_validation/meta/closed_loop/grip_the_cube_v2_validation_start10.json",
          "start_dataset": {
            "repo_id": "physical-ai-agent/so101-grip-the-cube-v2-validation",
            "root": "_workspace/so101_lerobot/grip_the_cube_v2_validation"
          }
        }
      ]
    }
  }
}
