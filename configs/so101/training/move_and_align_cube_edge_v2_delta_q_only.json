{
  "name": "move_and_align_cube_edge_v2_delta_q_only",
  "description": "Delta-q variant of move_and_align_cube_edge_v2_only. The source absolute-qpos datasets are preserved; this config trains on copied datasets whose action column stores action - observation.state.",
  "scenario": "move_and_align_cube_edge",
  "execution_policy": "single_smolvla_qwen_primitive",
  "task": "move_and_align_cube_edge",
  "action_mode": "delta_q",
  "delta_action_source": {
    "mode": "state_to_action",
    "source_config": "configs/so101/training/move_and_align_cube_edge_v2_only.json",
    "converter": "scripts/convert_so101_lerobot_actions_to_delta.py"
  },
  "train_dataset": {
    "name": "move_and_align_cube_edge_v2_delta_q_train",
    "repo_id": "physical-ai-agent/so101-move-and-align-cube-edge-train-v2-delta-q-300-ego-wrist-256",
    "root": "_workspace/so101_lerobot/move_and_align_cube_edge_train_v2_delta_q_300_ego_wrist_256_seed124000",
    "grid_bin_sidecar": "_workspace/so101_lerobot/move_and_align_cube_edge_train_v2_delta_q_300_ego_wrist_256_seed124000/meta/camera_grid_bins/observation_images_camera1_4x4_frame0.parquet",
    "expected_episodes": 300,
    "expected_frames": 21600
  },
  "validation_dataset": {
    "name": "move_and_align_cube_edge_delta_q_validation",
    "repo_id": "physical-ai-agent/so101-move-and-align-cube-edge-valid25-delta-q-ego-wrist-256",
    "root": "_workspace/so101_lerobot/move_and_align_cube_edge_valid25_delta_q_ego_wrist_256_seed123000",
    "expected_episodes": 25,
    "expected_frames": 1700
  },
  "camera_contract": {
    "observation.images.camera1": "egocentric_cam",
    "observation.images.camera2": "wrist_cam",
    "observation.images.camera3": "wrist_cam duplicate"
  },
  "prompt_contract": {
    "task": "Move above one visible {color} {shape} edge and align the gripper jaws around it.",
    "source": "move_and_align_cube_edge_v2 train split"
  },
  "dataset_generation_augmentation": {
    "generated_teacher_trajectories": true,
    "terminal_hold_included": true,
    "terminal_hold_steps": 20,
    "near_target_correction_included": true,
    "near_target_correction_ratio": 0.5,
    "near_target_joint_std": 0.075,
    "near_target_xy_std": 0.025
  },
  "training": {
    "batch_size": 32,
    "num_workers": 4,
    "policy_repo_id": "mhlee1215/so101-smolvla-move-and-align-cube-edge-v2-delta-q",
    "policy_push_to_hub": false,
    "steps_per_epoch": 675,
    "validation_max_batches": 32,
    "checkpoint_retention_policy": "best_val_and_closed_loop"
  },
  "predecoded_image_cache": {
    "root_env": "SO101_PREDECODED_CACHE_ROOT",
    "default_root": "_workspace/so101_image_cache",
    "train": "move_and_align_cube_edge_train_v2_delta_q_300_ego_wrist_256_seed124000",
    "validation": "move_and_align_cube_edge_valid25_delta_q_ego_wrist_256_seed123000"
  },
  "tensorboard": {
    "log_input_images_every_n_steps": 50,
    "log_input_metadata_every_n_steps": 50
  },
  "augmentation": {
    "state_jitter_std": 0.003,
    "state_jitter_arm_only": true,
    "state_dropout_prob": 0.02,
    "state_dropout_keep_gripper": true,
    "image_camera_dropout_prob": 0.0,
    "image_patch_dropout_prob": 0.0,
    "image_patch_mask_ratio": 0.15,
    "image_color_jitter": true,
    "image_sharpness_jitter": true,
    "image_affine_degrees": 5.0,
    "image_affine_translate": 0.05,
    "gpu_image_augmentation": true
  },
  "closed_loop": {
    "scenario": "move_and_align_cube_edge",
    "execution_policy": "single_smolvla_qwen_primitive",
    "runner": "qwen_chain",
    "action_rmse_sweep": {
      "enabled": true,
      "n_action_steps": [
        1,
        3,
        5,
        10,
        15,
        30,
        40,
        50
      ],
      "tensorboard_tag": "closed_loop/<test_id>/action_rmse_sweep"
    },
    "action_contract_mode": "processor_delta_q",
    "env_id": "MuJoCoPickLift-v1",
    "task_prompt": "Move above one visible green cube edge and align the gripper jaws around it.",
    "qwen_object": "green cube",
    "env_object_color": "green",
    "base_seed": 98100,
    "valid_mask_checkpoint": "_workspace/so101_valid_mask_head/qwen_edge_primitives/valid_mask_head.pt",
    "success_metric": "tcp_to_object_below_threshold",
    "success_threshold": 0.06,
    "test_cases": [
      {
        "id": "move_and_align_cube_edge_loop_validation",
        "description": "Starts from the first frame of the move_and_align_cube_edge loop_validation split and runs only the move_and_align_cube_edge primitive. The policy action is interpreted as delta-q.",
        "episodes": 10,
        "steps": 80,
        "seed": 98100,
        "start_contract": "move_and_align_cube_edge",
        "start_dataset": {
          "name": "move_and_align_cube_edge_loop_validation",
          "repo_id": "physical-ai-agent/so101-move-and-align-cube-edge-loop-validation10-ego-wrist-256",
          "root": "_workspace/so101_lerobot/move_and_align_cube_edge_loop_validation10_ego_wrist_256_seed123500",
          "expected_episodes": 10
        },
        "success_metric": "tcp_to_object_below_threshold",
        "success_threshold": 0.06,
        "task_prompt": "Move above one visible green cube edge and align the gripper jaws around it.",
        "qwen_object": "green cube",
        "env_object_color": "green",
        "plan_json": "configs/agent/qwen3_so101_tool_plan_move_and_align_cube_edge_green_cube.json"
      }
    ]
  }
}
