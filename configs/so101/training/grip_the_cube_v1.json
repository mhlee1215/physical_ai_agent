    "root": "_workspace/so101_lerobot/grip_the_cube_v1_eval50_axis_filtered_seed483000",
    "grid_bin_sidecar": "_workspace/so101_lerobot/grip_the_cube_v1_eval50_axis_filtered_seed483000/meta/camera_grid_bins/observation_images_camera1_4x4_frame0.parquet",
    "expected_episodes": 50,
