  "camera_contract": {
    "observation.images.camera1": "egocentric_cam",
    "observation.images.camera2": "wrist_cam",
    "observation.images.camera3": "wrist_cam duplicate"
  },
  "prompt_contract": {
    "task": "grip the {color} {shape} and lift",
    "generated_task": "grip the green cube and lift",
    "applies_to": [
      "pick_cube",
      "pick_from_top_cube",
      "grip_from_edge_cube",
      "grip_from_above_edge_cube",
      "grip_the_cube_v1"
    ]
  },
  "training": {
    "batch_size": 32,
    "num_workers": 4,
    "policy_repo_id": "mhlee1215/so101-smolvla-grip-the-cube-v1",
    "policy_push_to_hub": false,
    "steps_per_epoch": 684,
    "validation_max_batches": 64,
    "checkpoint_retention_policy": "best_val_and_closed_loop"
  },
  "action_chunk_consistency": {
    "steps": 15,
    "weight": 0.05
  },
  "action_smoothness": {
    "weight": 0.01,
    "include_gripper": false
  },
  "predecoded_image_cache": {
    "root_env": "SO101_PREDECODED_CACHE_ROOT",
    "default_root": "_workspace/so101_image_cache",
    "train": "grip_the_cube_v1_train200_axis_filtered_seed482000",
    "validation": "grip_the_cube_v1_eval50_axis_filtered_seed483000"
  },
  "closed_loop": {
    "runner": "picklift",
    "eval_skill_mode": "grip_the_cube_v1",
    "env_id": "MuJoCoPickLift-v1",
    "task_prompt": "grip the green cube and lift",
    "action_contract_mode": "processor",
    "record_rollout_gif": true,
    "action_rmse_sweep": {
      "enabled": true,
      "n_action_steps": [1, 3, 5, 10, 15, 30, 40, 50],
      "tensorboard_tag": "closed_loop/<test_id>/action_rmse_sweep"
    },
    "test_cases": [
      {
        "id": "grip_the_cube_v1",
        "episodes": 10,
        "steps": 120,
        "seed": 98100,
        "start_contract": "default_reset",
        "task_prompt": "grip the green cube and lift",
        "env_object_color": "green",
        "success_metric": "env_success",
        "start_dataset": {
          "repo_id": "physical-ai-agent/so101-grip-the-cube-v1-axis-filtered-eval50",
          "root": "_workspace/so101_lerobot/grip_the_cube_v1_eval50_axis_filtered_seed483000"
        }
      }
    ]
  },
  "tensorboard": {
    "log_input_images_every_n_steps": 50,
    "log_input_metadata_every_n_steps": 50
  },
  "dataset_generation": {
    "skill_mode": "grip_the_cube_v1",
    "target_object_color": "green",
    "target_object_shape": "cube",
    "ignored_bins": [0, 1, 2, 3, 4, 15],
    "ignored_cases": [
      "camera1 first frame object area below 20 pixels",
      "teacher infeasible spawn/candidate",
      "teacher replay failure",
      "pre-close gripper jaw not parallel to selected cube edge",
      "diagonal edge/corner grasp candidate"
    ],
    "start_positions": [
      "home pose",
      "mid pose between home and above-cube target with joint jitter"
    ],
    "phases": [
      "move_to_cube",
      "roll_align_with_cube_edge",
      "gripper_descend",
      "settle_aligned",
      "close",
      "lift",
      "terminal_hold"
    ],
    "alignment_contract": {
      "roll_alignment_phase": "roll_align_with_cube_edge",
      "roll_alignment_meaning": "adjust wrist_roll at the above-cube pose so the gripper jaw axis becomes parallel to the selected cube edge before descending",
      "descend_phase": "gripper_descend",
      "pre_close_required": true,
      "pre_close_edge_parallel_threshold_deg": 2.0,
      "pre_close_static_finger_xy_threshold": 0.012,
      "diagonal_edge_candidates_allowed": false
    },
    "approach_steps": 24,
    "settle_steps": 8,
    "close_steps": 32,
    "lift_steps": 48,
    "terminal_hold_steps": 20,
    "move_target_z_offset": 0.075,
    "near_target_joint_std": 0.055,
    "camera1_lookup_balanced": true,
    "teacher_feasible_spawn_lookup": true
  },
  "augmentation": {
    "state_jitter_std": 0.003,
    "state_jitter_arm_only": true,
    "state_dropout_prob": 0.02,
    "state_dropout_keep_gripper": true,
    "image_camera_dropout_prob": 0.0,
    "image_patch_dropout_prob": 0.0,
    "image_patch_mask_ratio": 0.0,
    "image_color_jitter": true,
    "image_sharpness_jitter": true,
    "image_affine_degrees": 3.0,
    "image_affine_translate": 0.03,
    "image_noise_std": 0.01,
    "image_motion_blur_prob": 0.1,
    "gpu_image_augmentation": true
  }
}
