{
  "schema_version": 1,
  "name": "ground_pickup_tiny_smoke",
  "description": "Config-first tiny readiness path for myCobot 280 cube-from-mat SmolVLA fine-tuning plumbing.",
  "robot": {
    "name": "myCobot 280 Pi + adaptive gripper",
    "model_profile": "mycobot_280_pi_adaptive_gripper",
    "state_dim": 7,
    "action_dim": 7,
    "joint_names": [
      "joint2_to_joint1",
      "joint3_to_joint2",
      "joint4_to_joint3",
      "joint5_to_joint4",
      "joint6_to_joint5",
      "joint7_to_joint6",
      "gripper_controller"
    ],
    "gripper_semantics": "lower command closes in the current ground-pickup POC"
  },
  "scenario": "ground_pickup_cube",
  "task_prompt": "pick up the cube from the work mat with the myCobot 280 Pi adaptive gripper",
  "object_suite": {
    "name": "object_suite_v0",
    "profile": "cube_from_mat_medium",
    "cube_half_size_m": 0.015,
    "cube_mass_kg": 0.032,
    "note": "object_suite_v0 is not implemented yet; these values mirror the deterministic ground-pickup POC."
  },
  "feature_contract": {
    "base_checkpoint": "lerobot/smolvla_base",
    "image_shape_chw": [
      3,
      256,
      256
    ],
    "state_key": "observation.state",
    "action_key": "action",
    "camera_contract": {
      "observation.images.camera1": "rendered_teacher_frame"
    },
    "state_names": [
      "joint2_to_joint1",
      "joint3_to_joint2",
      "joint4_to_joint3",
      "joint5_to_joint4",
      "joint6_to_joint5",
      "joint7_to_joint6",
      "gripper_controller"
    ],
    "action_names": [
      "joint2_to_joint1",
      "joint3_to_joint2",
      "joint4_to_joint3",
      "joint5_to_joint4",
      "joint6_to_joint5",
      "joint7_to_joint6",
      "gripper_controller"
    ]
  },
  "source_dataset": {
    "format": "mycobot_jsonl_v1",
    "root": "_workspace/mycobot_teacher_datasets/mycobot_280_pi_ground_pickup_poc_10eps",
    "expected_episodes": 10,
    "expected_min_frames": 100,
    "expected_generation_mode": "deterministic_fixed_task",
    "expected_randomization_enabled": false,
    "expected_teacher_attachment_enabled": false,
    "expected_object_teleport_during_pickup_lift": false,
    "required_success_criteria": {
      "final_cube_lift_m": 0.05,
      "final_gripper_cube_contact_pads": 2,
      "lift_best_sustained_two_pad_steps": 60,
      "post_lift_hold_best_sustained_two_pad_steps": 300,
      "post_lift_hold_min_cube_lift_m": 0.045,
      "max_pad_cube_penetration_m": 0.003
    },
    "generation_command": [
      "PYTHONPATH=src:.",
      "MUJOCO_GL=egl",
      "_workspace/worktrees/mycobot-280pi-adaptive/_workspace/venvs/mycobot-mujoco-py312/bin/python",
      "scripts/export_mycobot_280_ground_pickup_teacher_dataset.py",
      "--asset-root",
      "_workspace/worktrees/mycobot-280pi-adaptive/_vendor/mycobot_mujoco",
      "--official-gripper-root",
      "_workspace/worktrees/mycobot-280pi-adaptive/_vendor/mycobot_ros",
      "--output-dir",
      "_workspace/mycobot_teacher_datasets/mycobot_280_pi_ground_pickup_poc_10eps",
      "--episodes",
      "10",
      "--width",
      "256",
      "--height",
      "256",
      "--render-every",
      "1"
    ],
    "expected_all_frames_rendered": true
  },
  "lerobot_conversion": {
    "output_root": "_workspace/mycobot280_lerobot/ground_pickup_tiny_smoke",
    "repo_id": "physical-ai-agent/mycobot-280-ground-pickup-tiny-smoke",
    "converter_script": "scripts/export_mycobot_280_ground_pickup_lerobot_dataset.py",
    "native_converter_script": "scripts/convert_mycobot_280_pi_adaptive_jsonl_to_lerobot.py",
    "claim_boundary": "Conversion readiness only; native LeRobotDataset writing requires LeRobot runtime."
  },
  "training_smoke": {
    "policy_path": "lerobot/smolvla_base",
    "output_dir": "_workspace/mycobot280_training/ground_pickup_tiny_smoke",
    "batch_size": 1,
    "steps": 2,
    "max_batches": 1,
    "device": "auto",
    "tensorboard_dir": "_workspace/mycobot280_training/ground_pickup_tiny_smoke/tensorboard",
    "checkpoint_dir": "_workspace/mycobot280_training/ground_pickup_tiny_smoke/checkpoints",
    "claim_boundary": "Tiny smoke only; no policy success claim."
  },
  "closed_loop_stub": {
    "script": "scripts/evaluate_mycobot280_smolvla_policy.py",
    "output_dir": "_workspace/mycobot280_eval/ground_pickup_tiny_smoke",
    "episodes": 3,
    "metrics": [
      "success",
      "final_cube_lift_m",
      "post_lift_hold_steps",
      "two_pad_contact_retention_steps",
      "max_pad_cube_penetration_m",
      "failure_reason"
    ],
    "future_comparison_rows": [
      "unfinetuned_baseline",
      "finetuned_policy_only",
      "finetuned_policy_plus_verifier_retry"
    ]
  }
}
